---

<section class="card" aria-labelledby="resultados-title">
  <div class="head-row">
    <h2 id="resultados-title">Resultados</h2>
    <div class="actions-row">
      <button type="button" id="btn-copiar" class="btn small secondary" title="Copiar resumen">
        <i class="bi bi-clipboard"></i>
      </button>
      <button type="button" id="btn-exportar" class="btn small secondary" title="Exportar imagen">
        <i class="bi bi-image"></i>
      </button>
    </div>
  </div>
  <div id="resultado" class="resultado" aria-live="polite"></div>

  <div id="modal-export-overlay" class="modal-overlay" aria-hidden="true">
    <div
      class="modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-export-title"
    >
      <div class="modal-head">
        <h3 id="modal-export-title">Imagen del resumen</h3>
        <button
          type="button"
          id="modal-export-cerrar"
          class="btn secondary small"
          aria-label="Cerrar"
        >
          <i class="bi bi-x"></i>
        </button>
      </div>
      <img id="export-preview" class="export-preview" alt="Resumen del evento" />
      <div class="modal-actions">
        <button type="button" id="btn-export-descargar" class="btn success">
          <i class="bi bi-download"></i> Descargar
        </button>
        <button type="button" id="btn-export-compartir" class="btn">
          <i class="bi bi-share-fill"></i> Compartir
        </button>
      </div>
    </div>
  </div>
</section>

<script type="module" is:inline>
  const el = document.getElementById("resultado");
  const live = document.getElementById("live-region");

  function nivelEbriedad(ml) {
    if (ml <= 0) return { label: "Sobrio", emoji: "😐", color: "#a7b0c0", pct: 0 };
    if (ml <= 30) return { label: "Leve", emoji: "🙂", color: "#2ecc71", pct: 20 };
    if (ml <= 60) return { label: "Moderado", emoji: "😊", color: "#3aa8ff", pct: 40 };
    if (ml <= 100) return { label: "Alto", emoji: "😵", color: "#f39c12", pct: 60 };
    if (ml <= 150) return { label: "Muy alto", emoji: "🤢", color: "#ff4d4f", pct: 80 };
    return { label: "Extremo", emoji: "☠️", color: "#ff1744", pct: 100 };
  }

  function render() {
    const res = window.App.calcularResumen(
      window.App.getPersonas(),
      window.App.getProductos(),
    );
    const nivel = nivelEbriedad(res.alcoholPuroPorPersonaMl);
    el.innerHTML = `
      <div class="box">
        <strong>Costos</strong>
        <div class="line"><span class="label">Total</span><span>${window.App.fmtCOP.format(res.costoTotalCOP)}</span></div>
        <div class="line"><span class="label">Por persona</span><span>${window.App.fmtCOP.format(res.costoPorPersonaCOP)}</span></div>
      </div>
      <div class="box">
        <strong>Alcohol puro</strong>
        <div class="line"><span class="label">Total</span><span>${res.alcoholPuroTotalMl} ml</span></div>
        <div class="line"><span class="label">Por persona</span><span>${res.alcoholPuroPorPersonaMl} ml</span></div>
      </div>
      <div class="box">
        <strong>Volumen total</strong>
        <div class="line"><span class="label">Total</span><span>${res.volumenTotalMl} ml · ${res.volumenTotalL} L</span></div>
      </div>
      <div class="box">
        <strong>Nivel de ebriedad por persona</strong>
        <div class="nivel-indicator">
          <div class="nivel-bar-track">
            <div class="nivel-bar-fill" style="width:${nivel.pct}%; background:${nivel.color}"></div>
          </div>
          <div class="nivel-label" style="color:${nivel.color}">
            <span class="nivel-emoji">${nivel.emoji}</span>
            <span>${nivel.label}</span>
            <span class="muted">(${res.alcoholPuroPorPersonaMl} ml alcohol puro/persona)</span>
          </div>
        </div>
      </div>
    `;
    live.textContent = `Actualizado: total ${window.App.fmtCOP.format(res.costoTotalCOP)}, por persona ${window.App.fmtCOP.format(res.costoPorPersonaCOP)}, alcohol por persona ${res.alcoholPuroPorPersonaMl} ml.`;
  }

  function getEventName() {
    const evts = window.App.loadEventos();
    const id = window.App.getEventoActivoId();
    const evento = evts.find(e => e.id === id);
    return evento?.nombreEvento || "Sin nombre";
  }

  function buildSummary() {
    const App = window.App;
    const personas = App.getPersonas();
    const productos = App.getProductos();
    const res = App.calcularResumen(personas, productos);
    const nivel = nivelEbriedad(res.alcoholPuroPorPersonaMl);

    let text = `=== FARRA CALCULATOR ===\n`;
    text += `Evento: ${getEventName()}\n`;
    text += `Personas: ${personas}\n\n`;

    text += `--- Productos ---\n`;
    if (productos.length === 0) {
      text += `(Sin productos)\n`;
    } else {
      productos.forEach((p, i) => {
        const costo = p.precioUnidadCOP * p.cantidad;
        text += `${i + 1}. ${p.nombre}\n`;
        text += `   Precio/u: ${App.fmtCOP.format(p.precioUnidadCOP)} | Cantidad: ${p.cantidad} | ABV: ${p.abv}% | ml/u: ${p.mlUnidad} | Costo: ${App.fmtCOP.format(costo)}\n`;
      });
    }

    text += `\n--- Resumen ---\n`;
    text += `Costo total: ${App.fmtCOP.format(res.costoTotalCOP)}\n`;
    text += `Costo por persona: ${App.fmtCOP.format(res.costoPorPersonaCOP)}\n`;
    text += `Alcohol puro total: ${res.alcoholPuroTotalMl} ml\n`;
    text += `Alcohol puro por persona: ${res.alcoholPuroPorPersonaMl} ml\n`;
    text += `Volumen total: ${res.volumenTotalMl} ml (${res.volumenTotalL} L)\n`;
    text += `Nivel de ebriedad: ${nivel.emoji} ${nivel.label}\n`;

    return text;
  }

  // Copy to clipboard
  document.getElementById("btn-copiar").addEventListener("click", async () => {
    const text = buildSummary();
    try {
      await navigator.clipboard.writeText(text);
      window.toast("Copiado al portapapeles");
    } catch {
      window.toast("No se pudo copiar");
    }
  });

  // ---- Export como imagen PNG (canvas nativo, sin librerías) ----
  const exportOverlay = document.getElementById("modal-export-overlay");
  const exportClose = document.getElementById("modal-export-cerrar");
  const exportImg = document.getElementById("export-preview");
  const btnDescargar = document.getElementById("btn-export-descargar");
  const btnCompartir = document.getElementById("btn-export-compartir");
  let exportBlob = null;
  let exportFileName = "farra-resumen.png";
  let previewUrl = null;

  function fileNameFor(nombre) {
    const base = (nombre || "resumen")
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, "")
      .replace(/[^a-zA-Z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
      .toLowerCase();
    return `farra-${base || "resumen"}.png`;
  }

  // Dibuja el resumen en un canvas y devuelve { canvas, blob } via Promise
  function renderCanvas() {
    const App = window.App;
    const personas = App.getPersonas();
    const productos = App.getProductos();
    const res = App.calcularResumen(personas, productos);
    const nivel = nivelEbriedad(res.alcoholPuroPorPersonaMl);
    const nombreEvento = getEventName();

    const scale = 2; // nitidez retina
    const W = 560;
    const PAD = 32;
    const C = {
      bg: "#0f1115", card: "#171a21", text: "#e8ebf1",
      muted: "#a7b0c0", border: "#232735",
    };

    // Medir altura necesaria (personas siempre es >= 1)
    const headerH = 40 + 36 + 30 + 24 + 20;
    const prodHeaderH = 30;
    const prodRowH = 42;
    const prodBlockH = prodHeaderH + (productos.length || 1) * prodRowH + 16;
    const sumTitleH = 30;
    const sumLinesH = 5 * 26;
    const nivelH = 78;
    const footerH = 36;
    const H = PAD + headerH + prodBlockH + sumTitleH + sumLinesH + nivelH + footerH + PAD;

    const canvas = document.createElement("canvas");
    canvas.width = W * scale;
    canvas.height = H * scale;
    const ctx = canvas.getContext("2d");
    ctx.scale(scale, scale);
    ctx.textBaseline = "alphabetic";

    const FONT = '"Segoe UI", system-ui, -apple-system, Roboto, Arial, sans-serif';
    const money = (n) => App.fmtCOP.format(n);

    // Recorta texto con elipsis al ancho dado (según ctx.font actual).
    function fit(text, maxWidth) {
      if (ctx.measureText(text).width <= maxWidth) return text;
      let t = text;
      while (t.length > 1 && ctx.measureText(t + "…").width > maxWidth) {
        t = t.slice(0, -1);
      }
      return t + "…";
    }

    function roundRect(x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    // Fondo + tarjeta
    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, W, H);
    roundRect(12, 12, W - 24, H - 24, 16);
    ctx.fillStyle = C.card;
    ctx.fill();
    ctx.strokeStyle = C.border;
    ctx.lineWidth = 1;
    ctx.stroke();

    const x = PAD;
    const xRight = W - PAD;
    let y = PAD + 28;

    // Título
    ctx.fillStyle = C.text;
    ctx.font = `700 26px ${FONT}`;
    ctx.textAlign = "center";
    ctx.fillText("🍻 Farra Calculator", W / 2, y);
    y += 34;

    // Evento + personas
    ctx.textAlign = "left";
    ctx.font = `600 19px ${FONT}`;
    ctx.fillText(fit(nombreEvento, xRight - x), x, y);
    y += 26;
    ctx.font = `400 14px ${FONT}`;
    ctx.fillStyle = C.muted;
    ctx.fillText(`${personas} persona${personas === 1 ? "" : "s"}`, x, y);
    y += 26;

    function divider() {
      ctx.strokeStyle = C.border;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(xRight, y);
      ctx.stroke();
      y += 22;
    }
    divider();

    // Productos
    ctx.fillStyle = C.text;
    ctx.font = `700 16px ${FONT}`;
    ctx.fillText("Productos", x, y);
    y += 26;

    if (productos.length === 0) {
      ctx.fillStyle = C.muted;
      ctx.font = `400 14px ${FONT}`;
      ctx.fillText("Sin productos", x, y);
      y += prodRowH - 14;
    } else {
      for (const p of productos) {
        const costoStr = money(p.precioUnidadCOP * p.cantidad);
        ctx.fillStyle = C.text;
        ctx.font = `600 15px ${FONT}`;
        const maxNameW = xRight - x - ctx.measureText(costoStr).width - 16;
        ctx.textAlign = "left";
        ctx.fillText(fit(p.nombre, maxNameW), x, y);
        ctx.textAlign = "right";
        ctx.fillText(costoStr, xRight, y);
        y += 18;
        ctx.fillStyle = C.muted;
        ctx.font = `400 12px ${FONT}`;
        ctx.textAlign = "left";
        ctx.fillText(
          fit(
            `${p.cantidad} u · ${p.abv}% ABV · ${p.mlUnidad} ml/u · ${money(p.precioUnidadCOP)}/u`,
            xRight - x,
          ),
          x,
          y,
        );
        y += prodRowH - 18;
      }
    }
    y += 4;
    divider();

    // Resumen
    ctx.fillStyle = C.text;
    ctx.font = `700 16px ${FONT}`;
    ctx.textAlign = "left";
    ctx.fillText("Resumen", x, y);
    y += 26;

    const lines = [
      ["Costo total", money(res.costoTotalCOP)],
      ["Costo por persona", money(res.costoPorPersonaCOP)],
      ["Alcohol puro total", `${res.alcoholPuroTotalMl} ml`],
      ["Alcohol puro por persona", `${res.alcoholPuroPorPersonaMl} ml`],
      ["Volumen total", `${res.volumenTotalMl} ml · ${res.volumenTotalL} L`],
    ];
    for (const [label, value] of lines) {
      ctx.font = `400 14px ${FONT}`;
      ctx.fillStyle = C.muted;
      ctx.textAlign = "left";
      ctx.fillText(label, x, y);
      ctx.fillStyle = C.text;
      ctx.font = `600 14px ${FONT}`;
      ctx.textAlign = "right";
      ctx.fillText(value, xRight, y);
      y += 26;
    }
    y += 4;

    // Nivel de ebriedad
    ctx.textAlign = "left";
    ctx.fillStyle = C.muted;
    ctx.font = `400 13px ${FONT}`;
    ctx.fillText("Nivel de ebriedad por persona", x, y);
    y += 16;
    const barW = xRight - x;
    roundRect(x, y, barW, 10, 5);
    ctx.fillStyle = "#0c0f14";
    ctx.fill();
    if (nivel.pct > 0) {
      roundRect(x, y, Math.max(10, (barW * nivel.pct) / 100), 10, 5);
      ctx.fillStyle = nivel.color;
      ctx.fill();
    }
    y += 28;
    ctx.fillStyle = nivel.color;
    ctx.font = `700 16px ${FONT}`;
    ctx.fillText(`${nivel.emoji} ${nivel.label}`, x, y);

    // Footer
    ctx.fillStyle = C.muted;
    ctx.font = `400 11px ${FONT}`;
    ctx.textAlign = "center";
    ctx.fillText(
      new Date().toLocaleDateString("es-CO", { year: "numeric", month: "long", day: "numeric" }),
      W / 2,
      H - PAD + 4,
    );

    return new Promise((resolve) => {
      canvas.toBlob((blob) => resolve({ blob, nombreEvento }), "image/png");
    });
  }

  function openExport() {
    exportOverlay.classList.add("open");
    exportOverlay.setAttribute("aria-hidden", "false");
    document.body.classList.add("modal-open");
  }

  function closeExport() {
    exportOverlay.classList.remove("open");
    exportOverlay.setAttribute("aria-hidden", "true");
    document.body.classList.remove("modal-open");
    if (previewUrl) {
      URL.revokeObjectURL(previewUrl);
      previewUrl = null;
    }
    exportImg.removeAttribute("src");
    document.getElementById("btn-exportar").focus();
  }

  document.getElementById("btn-exportar").addEventListener("click", async () => {
    try {
      const { blob, nombreEvento } = await renderCanvas();
      if (!blob) throw new Error("toBlob falló");
      exportBlob = blob;
      exportFileName = fileNameFor(nombreEvento);
      if (previewUrl) URL.revokeObjectURL(previewUrl);
      previewUrl = URL.createObjectURL(blob);
      exportImg.src = previewUrl;
      openExport();
    } catch {
      window.toast("No se pudo generar la imagen");
    }
  });

  exportClose.addEventListener("click", closeExport);
  exportOverlay.addEventListener("click", (e) => {
    if (e.target === exportOverlay) closeExport();
  });

  btnDescargar.addEventListener("click", () => {
    if (!previewUrl) return;
    const a = document.createElement("a");
    a.href = previewUrl;
    a.download = exportFileName;
    a.click();
    window.toast("Imagen descargada");
  });

  btnCompartir.addEventListener("click", async () => {
    if (!exportBlob) return;
    const file = new File([exportBlob], exportFileName, { type: "image/png" });
    if (navigator.canShare && navigator.canShare({ files: [file] })) {
      try {
        await navigator.share({ files: [file], title: "Farra Calculator" });
      } catch {
        /* usuario canceló */
      }
    } else {
      window.toast("Compartir no disponible; descargando…");
      btnDescargar.click();
    }
  });

  window.addEventListener("app:state", render);
  window.addEventListener("DOMContentLoaded", render);
</script>
